- breadcrumb :dashboards, @workbench

.page_content
  .container-fluid
    - if @dashboards.any?
      .row
        .col-lg-12
          = table_builder_2 @dashboards,
            [ \
              TableBuilderHelper::Column.new( \
                key: :name, \
                attribute: 'name', \
                sortable: false, \
                link_to: lambda do |dashboard| \
                  workbench_dashboard_path(@workbench,dashboard) \
                end \
              ), \
              TableBuilderHelper::Column.new( \
                key: :description, \
                attribute: Proc.new { |dashboard| dashboard.description&.truncate(100) }, \
                sortable: false \
              ), \
              TableBuilderHelper::Column.new( \
                key: :widgets, \
                attribute: Proc.new { |dashboard| dashboard.widgets.count }, \
                sortable: false \
              ), \
            ],\
            cls: 'table has-filter has-search'

          = new_pagination @dashboards, 'pull-right'

    - else
      .row.mt-xs
        .col-lg-12
          = replacement_msg t('dashboards.search_no_results')
