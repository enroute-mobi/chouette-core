- breadcrumb :publications, @workgroup

.page_content x-data="{ saveSearchPanel: false, graphPanel: #{@search.graphical?} }"
  .container-fluid
    .row
      .col-lg-12
        = render 'filters'

    - if @chart && !@chart.empty?
      = @chart.to_chartkick(self, download: true)

    - elsif @publications.any?
      .row
        .col-lg-12
          = table_builder_2 @publications,
            [ \
              TableBuilderHelper::Column.new( \
                key: :publication_setup, \
                attribute: ->(publication){ link_to(publication.publication_setup.name, [@workgroup, publication.publication_setup])} \
              ), \
              TableBuilderHelper::Column.new( \
                key: :parent, \
                attribute: Proc.new do |publication| \
                  publication.parent ? link_to("#{publication.parent.class.ts} #{publication.parent.name}", [@workgroup, publication.publication_setup, publication]) : '-' \
                end, \
              ), \
              TableBuilderHelper::Column.new( \
                key: :status, \
                attribute: Proc.new { |n| operation_user_status(n) }, \
              ), \
              TableBuilderHelper::Column.new( \
                key: :created_at, \
                attribute: ->(publication){ link_to(l(publication.created_at, format: :short_with_time), [@workgroup, publication.publication_setup, publication])} \
              ), \
              TableBuilderHelper::Column.new( \
                key: :started_at, \
                attribute: ->(publication){ publication.started_at ? link_to(l(publication.started_at, format: :short_with_time), [@workgroup, publication.publication_setup, publication]) : '-' } \
              ), \
              TableBuilderHelper::Column.new( \
                key: :ended_at, \
                attribute: ->(publication){ publication.ended_at ? link_to(l(publication.ended_at, format: :short_with_time), [@workgroup, publication.publication_setup, publication]) : '-' } \
              ), \
            ],
            cls: 'table has-filter'

          = new_pagination @publications, 'pull-right'

    - else
      .row.mt-xs
        .col-lg-12
          = replacement_msg t('publications.search_no_results')
